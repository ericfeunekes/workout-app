# Copy to .release.env, run `chmod 600 .release.env`, or pass with:
#   make release-preflight RELEASE_CONFIG=/path/to/release.env
#
# Keep real secret values and private keys out of the repo. This file documents
# names only.

SETMARK_RELEASE_TEAM_ID=
SETMARK_RELEASE_APP_STORE_APP_ID=
SETMARK_RELEASE_BUNDLE_ID=com.ericfeunekes.WorkoutDB
SETMARK_RELEASE_WATCH_BUNDLE_ID=com.ericfeunekes.WorkoutDB.watchkitapp
SETMARK_RELEASE_BETA_GROUP_ID=

SETMARK_RELEASE_ASC_KEY_ID=
SETMARK_RELEASE_ASC_ISSUER_ID=
SETMARK_RELEASE_ASC_KEY_PATH=/Users/ericfeunekes/.appstoreconnect/private_keys/AuthKey_<key-id>.p8

SETMARK_RELEASE_KEYCHAIN_PATH=/Users/ericfeunekes/Library/Keychains/setmark-release.keychain-db
SETMARK_RELEASE_KEYCHAIN_PASSWORD_PATH=/Users/ericfeunekes/.appstoreconnect/signing/setmark-release-keychain.password
SETMARK_RELEASE_SIGN_IDENTITY=Apple Distribution
SETMARK_RELEASE_IOS_PROFILE_NAME=Setmark iOS App Store
SETMARK_RELEASE_WATCH_PROFILE_NAME=Setmark Watch App Store

# Explicit repair only: required by `make release-repair-signing`, not by
# routine `make release-preflight` or `make release-testflight`.
# SETMARK_RELEASE_SIGNING_P12_PATH=/Users/ericfeunekes/.appstoreconnect/signing/setmark-release-apple-distribution.p12
# SETMARK_RELEASE_SIGNING_P12_PASSWORD_PATH=/Users/ericfeunekes/.appstoreconnect/signing/setmark-release-p12.password
# SETMARK_RELEASE_SIGNING_CHAIN_PATHS=/Users/ericfeunekes/.appstoreconnect/signing/AppleWWDRCAG3.cer

SETMARK_RELEASE_DEVELOPER_DIR=/Applications/Xcode-26.5.app/Contents/Developer
SETMARK_RELEASE_PROJECT_PATH=app/WorkoutDB.xcodeproj
SETMARK_RELEASE_SCHEME=WorkoutDB
SETMARK_RELEASE_CONFIGURATION=Release
SETMARK_RELEASE_ROOT=scratch/qa-runs
SETMARK_RELEASE_REQUIRE_HEALTHKIT_ENTITLEMENT=true
# Optional fail-closed tester-count assertion when App Store Connect exposes it.
# SETMARK_RELEASE_EXPECTED_INTERNAL_TESTER_COUNT=1

# Optional recovery overrides. Leave unset for normal releases so every run gets
# a fresh archive/export directory under SETMARK_RELEASE_ROOT.
# SETMARK_RELEASE_ARCHIVE_PATH=/tmp/Setmark-TestFlight.xcarchive
# SETMARK_RELEASE_EXPORT_PATH=/tmp/SetmarkExport
