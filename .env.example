# Copy to .env and fill in. .env is gitignored.
# The server reads these via pydantic-settings with env_prefix="WORKOUTDB_".

# Bearer token the iOS app sends on every request. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Minimum length: 16 characters (server refuses to start otherwise).
# The same value is baked into the app (first-run setup pastes it into the app's settings).
WORKOUTDB_BEARER_TOKEN=

# The app_user UUID this bearer token authenticates as (ADR-2026-04-17: routes resolve
# user_id from the token, never from request bodies/queries). Generate once with:
#   python -c "import uuid; print(uuid.uuid4())"
# A row is auto-created on first startup if missing, named per WORKOUTDB_USER_NAME.
WORKOUTDB_USER_ID=

# Display name for the auto-created app_user row. Default: "Eric".
# WORKOUTDB_USER_NAME=Eric

# Where SQLite lives on the home server. Absolute path preferred.
WORKOUTDB_DB_PATH=/var/lib/workoutdb/workout.db

# Server bind address. Tailscale handles reachability — bind to the tailnet interface.
WORKOUTDB_HOST=0.0.0.0
WORKOUTDB_PORT=8080

# Set to true for verbose logging; never in prod.
WORKOUTDB_DEBUG=false
